def intro():
    print("Welcome to the Adventure Game!")
    print("You wake up in a dark forest. Two paths lie ahead.")
    choice = input("Do you go left or right? (left/right): ")
    if choice.lower() == "left":
        left_path()
    elif choice.lower() == "right":
        right_path()
    else:
        print("Invalid choice. Try again.")
        intro()

def left_path():
    print("You encounter a friendly wizard.")
    choice = input("Do you talk to him or ignore him? (talk/ignore): ")
    if choice.lower() == "talk":
        print("The wizard gives you a magic sword. You win!")
    else:
        print("You walk away and get lost. Game over.")

def right_path():
    print("You find a cave with treasure.")
    choice = input("Do you enter or stay outside? (enter/stay): ")
    if choice.lower() == "enter":
        print("You find gold and jewels. You win!")
    else:
        print("A bear finds you outside. Game over.")


intro()
